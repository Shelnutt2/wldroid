compositor/native/subprojects/wlroots
compositor/native/subprojects/virglrenderer
compositor/native/subprojects/proot
# But track .wrap files and packagefiles
!compositor/native/subprojects/*.wrap
!compositor/native/subprojects/packagefiles/

# Downloaded talloc source (not a git submodule — fetched by build-proot.sh)
external/talloc/

